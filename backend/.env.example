# Pump TCG Backend configuration

# Solana RPC (Helius recommended)
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY

# Pinata JWT for IPFS uploads (optional, for production)
PINATA_JWT=YOUR_PINATA_JWT

# Treasury wallet private key (JSON array or base58)
# In production, store as a file path or encrypted env var
# TREASURY_KEYFILE=/path/to/treasury.json
# or
# TREASURY_PRIVATE_KEY=base58_encoded_private_key

# Server port
PORT=3001