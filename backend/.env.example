# PumpBattle Backend — Environment Configuration

# Solana RPC (Helius recommended for Pump.fun)
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY

# Pinata IPFS (for image + metadata uploads)
PINATA_API_KEY=YOUR_PINATA_API_KEY
PINATA_SECRET_KEY=YOUR_PINATA_SECRET_KEY

# Treasury wallet private key (ONLY for dev; use Vercel env in prod)
# Format: base58 string OR JSON array of 64 integers
# Example: [1,2,3,...64] or "8fh2jkl..."
TREASURY_PRIVATE_KEY=YOUR_PRIVATE_KEY

# Database (optional; defaults to /tmp/game.db for Vercel)
# DATABASE_PATH=./game.db

# Uploads directory (Vercel uses /tmp by default)
# UPLOADS_DIR=/tmp/pump-tcg-uploads

# Server port (Vercel ignores this)
# PORT=3001